# Exercise all built-in function categories
(let ((a (add 1 2))
      (b (sub 10 3))
      (c (mul 4 5))
      (d (div 20 4))
      (e (mod 7 3))
      (f (neg 5))
      (g (addf 1.0 2.0))
      (h (eq 1 1))
      (i (lt 1 2))
      (j (and true false))
      (k (or false true))
      (l (not true))
      (m (concat "hello" " world"))
      (n (strlen "abc"))
      (o (int-to-flt 42))
      (p (flt-to-int 3.14))
      (q (int-to-str 99))
      (r (flt-to-str 2.71)))
  a)
