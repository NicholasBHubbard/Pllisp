# Exercise built-in operations
(progn
  (print (int-to-str (add 1 2)))
  (print (int-to-str (sub 10 3)))
  (print (int-to-str (mul 4 5)))
  (print (int-to-str (div 20 4)))
  (print (int-to-str (mod 7 3)))
  (print (int-to-str (neg 5)))
  (print (if (eqi 1 1) "eqi: true" "eqi: false"))
  (print (if (lti 1 2) "lti: true" "lti: false"))
  (print (if (and true false) "and: true" "and: false"))
  (print (if (or false true) "or: true" "or: false"))
  (print (if (not true) "not: true" "not: false"))
  (print (concat "hello" " world"))
  (print (int-to-str (strlen "abc"))))
