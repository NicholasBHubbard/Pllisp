# Pattern matching with case expressions

(type Result ()
  (Ok %INT)
  (Err %STR))

(fun show-result ((r %Result))
  (case r
    ((Ok n) (concat "ok: " (int-to-str n)))
    ((Err s) (concat "error: " s))))

# Nested patterns
(type Tree ()
  (Leaf %INT)
  (Branch %Tree %Tree))

(fun sum-tree ((t %Tree))
  (case t
    ((Leaf n) n)
    ((Branch l r) (add (sum-tree l) (sum-tree r)))))

(progn
  (print (show-result (Ok 42)))
  (print (show-result (Err "not found")))
  (print (int-to-str (sum-tree (Branch (Leaf 1) (Branch (Leaf 2) (Leaf 3)))))))
