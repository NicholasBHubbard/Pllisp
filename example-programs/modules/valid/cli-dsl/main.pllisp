(import CLI)

(fun list-len ((xs %(List %STR))) %INT
  (case xs
    ((Empty) 0)
    ((Cons _ rest) (add 1 (list-len rest)))))

(CLI
  (:flag :verbose "-v" "--verbose")
  (:option :output "-o" "--output")
  (:rest :extras))

(print (if verbose "true" "false"))
(case output
  ((Just path) (print path))
  (_ (print "missing")))
(print (int-to-str (list-len extras)))
